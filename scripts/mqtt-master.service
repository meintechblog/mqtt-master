[Unit]
Description=MQTT Master Web Dashboard
After=network.target mosquitto.service
Wants=mosquitto.service

[Service]
Type=simple
User=mqtt-master
Group=mqtt-master
WorkingDirectory=/opt/mqtt-master/webapp
ExecStart=/opt/mqtt-master/venv/bin/python app.py
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
